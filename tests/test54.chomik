#!/usr/local/bin/chomik


# This test checks the addition. I used incorrect relacement policy in execute.cc, and I got a code with the
# variables values replaced (because I chose the exhaustive one, while I should have taken the literal one).
# Anyway, the addition was OK.

let knowledge about chomik prefix = value integer 0;

let <knowledge about chomik prefix> knowledge about chomik the current snippet number = value integer 17;


let <knowledge about chomik prefix> knowledge about chomik add the chomik snippet = value code
{
    <print "originally got number" <<knowledge about chomik prefix> knowledge about chomik the current snippet number>>;
    <print "and the add result equals" <the add result "integer">>;

    <add "integer" <<knowledge about chomik prefix> knowledge about chomik the current snippet number> 1>;
    let <knowledge about chomik prefix> knowledge about chomik the current snippet number = <the add result "integer">;

    <print "add result \"integer\" contains" <the add result "integer">>;
};

<<knowledge about chomik prefix> knowledge about chomik add the chomik snippet>;

let the program return = value integer 0;

let control lower = value code { let the program return = value integer 1; };
let control greater = value code { let the program return = value integer 1; };
let control equal = value code { };

<compare "integer" <<knowledge about chomik prefix> knowledge about chomik the current snippet number> 18>;

