#!/usr/local/bin/chomik


<print "The perform test ... has been loaded">;

# This is not really a test - it always succeeds. But it is used by the test60.sh wrapper
# in order to check a value

let assign the result depending on lower = value code
{
	<print "we assign the program return with 1">;
	let the program return = value integer 1;
};

let assign the result depending on greater = value code
{
	<print "we assign the program return with 1">;
	let the program return = value integer 1;
};

let assign the result depending on equal = value code
{
	<print "we assign the program return with 0">;
	let the program return = value integer 0;
};

let perform test (A: integer) and (B: integer) = value code
{
	let v 1 = value integer [(A:integer)];
	let v 2 = value integer [(B:integer)];

	<print "value" (NUMBER:range 1..2) " is equal " <v (NUMBER:range 1..2)>>;

	<compare "integer" <v 1> <v 2>>;

	#<print memory report>;

	<print "the compare result equals" <the compare result>>;
	<assign the result depending on <the compare result>>;

	<print "now the program return equals" <the program return>>;
};


